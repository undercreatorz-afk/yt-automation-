    "Upload Audio to Cloudinary": { "main": [[{ "node": "Pexels - Wealth Footage", "type": "main", "index": 0 }]] },
    "Pexels - Wealth Footage": { "main": [[{ "node": "Combine Assets", "type": "main", "index": 0 }]] },
    "Combine Assets": { "main": [[{ "node": "Creatomate - Render Finance Short", "type": "main", "index": 0 }]] },
